#: ../../search/toc.rst:56
msgid "**Keyword**: Search for specific terms used in the email body."
msgstr "**Keyword**: Search for specific terms used in the email body."

#: ../../search/toc.rst:57
msgid "**Subject**: Search in email subjects."
msgstr "**Subject**: Search in email subjects."

#: ../../search/toc.rst:58
msgid "**From**: Search for emails received from a specific email address."
msgstr "**From**: Search for emails received from a specific email address."

#: ../../search/toc.rst:59
msgid "**To**: Search for emails sent to a specific email address."
msgstr "**To**: Search for emails sent to a specific email address."

#: ../../search/toc.rst:60
msgid ""
"**Attachment type**: Search for specific attachment formats such as PDF, "
"text document, images, etc."
msgstr ""
"**Attachment type**: Search for specific attachment formats such as PDF, "
"text document, images, etc."

